APP_NAME="AI Voice Intelligence API"
DEBUG=false

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai_voice_intelligence?retryWrites=true&w=majority
MONGODB_DB_NAME=ai_voice_intelligence

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant
GROQ_INSIGHT_MODEL=llama-3.1-8b-instant
GROQ_QA_MODEL=llama-3.1-8b-instant

ASSEMBLYAI_API_KEY=

TRANSCRIPTION_ENGINE=faster-whisper
TRANSCRIPTION_MODEL=base
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8
TRANSCRIPTION_LANGUAGE=
TRANSCRIPTION_SAMPLE_RATE=16000
TRANSCRIPTION_CHANNELS=1

DIARIZATION_ENGINE=heuristic
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_DEFAULT_SPEAKERS=2
DIARIZATION_MIN_SPEAKERS=1
DIARIZATION_MAX_SPEAKERS=10
DIARIZATION_CLUSTERING_THRESHOLD=0.7
HUGGINGFACE_TOKEN=

MAX_UPLOAD_MB=150
QA_CHUNK_MAX_CHARS=1800
QA_CHUNK_OVERLAP_SEGMENTS=1
QA_RETRIEVAL_TOP_K=4
